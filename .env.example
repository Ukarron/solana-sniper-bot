# ── RPC ──────────────────────────────────────────────
RPC_HTTP=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
RPC_WSS=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=YOUR_KEY

# ── Wallet ───────────────────────────────────────────
PRIVATE_KEY=your_base58_private_key

# ── Jupiter API ──────────────────────────────────────
JUPITER_API_KEY=your_jupiter_api_key

# ── Telegram ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_CHAT_ID=123456789

# ── Trading ──────────────────────────────────────────
BUY_AMOUNT_SOL=0.1
MAX_SLIPPAGE_BPS=300
JITO_TIP_LAMPORTS=100000
PAPER_TRADING=true

# ── Safety filters ───────────────────────────────────
MIN_LIQUIDITY_SOL=10
MAX_RUGCHECK_SCORE=50000
MAX_TOP_HOLDER_PCT=50.0
HONEYPOT_INITIAL_DELAY=10
HONEYPOT_RETRY_DELAY=10
HONEYPOT_MAX_RETRIES=2

# ── Early activity ───────────────────────────────────
WAIT_BEFORE_ANALYSIS_SEC=15
MIN_UNIQUE_BUYERS=3
MAX_SINGLE_BUYER_PCT=50.0

# ── Take-profit / Stop-loss ──────────────────────────
STOP_LOSS_PCT=35
TP1_TRIGGER=2.0
TP1_TRAILING_PCT=20.0
TP1_SELL_PCT=40.0
TP2_TRIGGER=4.0
TP2_TRAILING_PCT=25.0
TP2_SELL_PCT=30.0
TRAILING_STOP_ACTIVATION=1.8
TRAILING_STOP_PCT=30.0
MAX_HOLD_TIME_HOURS=12

# ── Risk management ─────────────────────────────────
MAX_CONCURRENT_POSITIONS=5
ESTIMATED_WIN_RATE=0.35

# ── Misc ─────────────────────────────────────────────
PRICE_CHECK_INTERVAL_SEC=5
LOG_LEVEL=INFO
